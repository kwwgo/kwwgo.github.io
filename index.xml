&lt;script>
ispeakBber
.init({
el: '#speak', // 容器选择器
name: 'kwwgoo🦄', // 显示的昵称
envId: 'twikoo-3gos5ikbf8bca455', // 环境id
region: 'ap-shanghai', // 腾讯云地址，默认为上海
limit: 10, // 每次加载的条数，默认为5
avatar: 'https://cdn.jsdelivr.net/gh/kwwgoo/cdn/custom/img.jpg',
fromColor:'rgb(245, 150, 170)', // 下方标签背景颜色 默认 rgb(245, 150, 170)
